<h1><%= title  %></h1>
<% messages.forEach((message,index) => { %>
    <article>
        <h2> <%= message.user %></h2>
        <p><%= message.text %></p>
        <p><%= `date published: ${message.added.toLocaleString()}` %></p>
       <a href="/messages/<%= index %>">Open this message</a>
    </article>
    
<% }) %>
<p>
  <a href="/new">Add a Post</a>
</p>